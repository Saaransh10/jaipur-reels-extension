{
  "manifest_version": 3,
  "name": "Jaipur Reels Explorer",
  "version": "1.0.0",
  "description": "Scrolls through Instagram Reels, filters Jaipur-related content in real-time, and compiles an elegant local list.",
  "permissions": [
    "sidePanel",
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://www.instagram.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://*.instagram.com/*"],
      "js": ["content-script.js"]
    }
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {},
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
